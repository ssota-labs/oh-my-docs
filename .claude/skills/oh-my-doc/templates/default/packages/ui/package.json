{
  "name": "@oh-my-docs/ui",
  "version": "0.1.0",
  "description": "Reusable Fumadocs document components for docs-first product workspaces.",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "test": "node --test --experimental-strip-types src/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "exports": {
    ".": "./src/index.ts",
    "./canvas": "./src/components/canvas.tsx",
    "./components/*": "./src/components/*.tsx",
    "./decision": "./src/components/decision.tsx",
    "./doc-kind": "./src/components/doc-kind.tsx",
    "./doc-status": "./src/components/doc-status.tsx",
    "./fumadocs": "./src/fumadocs.ts",
    "./inline-toc": "./src/components/inline-toc.tsx",
    "./lib/*": "./src/lib/*.ts",
    "./mdx": "./src/mdx.tsx",
    "./navigation": "./src/navigation.ts",
    "./provider": "./src/provider.ts",
    "./sidebar-folder": "./src/components/sidebar-folder.tsx",
    "./spec-version": "./src/components/spec-version.tsx"
  },
  "files": [
    "src",
    "!src/**/*.test.ts"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ssota-labs/oh-my-docs.git",
    "directory": "packages/ui"
  },
  "homepage": "https://github.com/ssota-labs/oh-my-docs/tree/main/packages/ui",
  "license": "MIT",
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@xyflow/react": "^12.11.2",
    "fumadocs-core": "^16.11.5",
    "fumadocs-ui": "^16.11.5",
    "lucide-react": "^1.25.0",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "next": "^16.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/mdx": "^2.0.14",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "typescript": "^5.9.3"
  },
  "private": true
}
