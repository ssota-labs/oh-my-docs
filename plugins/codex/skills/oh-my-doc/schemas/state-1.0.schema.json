{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oh-my-docs.dev/schemas/state-1.0.schema.json",
  "title": "Oh My Docs state",
  "type": "object",
  "required": ["contractVersion", "skillVersion", "templateVersion", "uiSnapshot", "projectDigest", "inventory", "files"],
  "properties": {
    "contractVersion": { "const": "1.0" },
    "skillVersion": { "type": "string" },
    "templateVersion": { "type": "string" },
    "uiSnapshot": {
      "type": "object",
      "required": ["distribution", "vocabularyDigest"],
      "properties": {
        "distribution": { "const": "skill-template" },
        "vocabularyDigest": { "type": "string" }
      }
    },
    "projectDigest": { "type": "string" },
    "inventory": { "type": "object" },
    "files": { "type": "object" }
  },
  "additionalProperties": true
}
