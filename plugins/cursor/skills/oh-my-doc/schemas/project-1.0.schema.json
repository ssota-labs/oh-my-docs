{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oh-my-docs.dev/schemas/project-1.0.schema.json",
  "title": "Oh My Docs project contract",
  "type": "object",
  "required": ["contractVersion", "mode", "paths", "informationArchitecture", "lifecycles", "ui", "ownership"],
  "properties": {
    "contractVersion": { "const": "1.0" },
    "mode": { "enum": ["greenfield", "brownfield"] },
    "paths": {
      "type": "object",
      "required": ["docs", "ui", "content", "templates"],
      "properties": {
        "docs": { "type": "string" },
        "ui": { "type": "string" },
        "content": { "type": "string" },
        "templates": { "type": "string" }
      }
    },
    "informationArchitecture": {
      "type": "object",
      "required": ["sections", "catalogs"],
      "properties": {
        "sections": { "type": "array" },
        "catalogs": { "type": "array" }
      }
    },
    "lifecycles": { "type": "object" },
    "ui": {
      "type": "object",
      "required": ["base", "distribution", "shellDependencies", "vocabulary"],
      "properties": {
        "base": { "const": "fumadocs" },
        "distribution": { "const": "skill-template" },
        "shellDependencies": {
          "type": "array",
          "items": { "type": "string" }
        },
        "vocabulary": { "type": "array" }
      }
    },
    "ownership": { "type": "object" }
  },
  "additionalProperties": true
}
