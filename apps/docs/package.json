{
  "name": "@oh-my-docs/docs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build && pnpm run check:planning",
    "start": "next start",
    "postinstall": "fumadocs-mdx",
    "test": "node --test --experimental-strip-types scripts/*.test.ts",
    "typecheck": "tsc --noEmit",
    "check:planning": "node --experimental-strip-types scripts/check-planning.ts"
  },
  "dependencies": {
    "fumadocs-core": "^16.11.5",
    "fumadocs-mdx": "^15.2.0",
    "fumadocs-ui": "^16.11.5",
    "next": "^16.1.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.0",
    "@types/mdx": "^2.0.13",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "postcss": "^8.5.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.7.3",
    "yaml": "^2.9.0"
  }
}
