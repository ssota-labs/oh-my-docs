{
  "name": "oh-my-docs",
  "version": "0.1.0",
  "description": "Scaffold and maintain docs-first product workspaces.",
  "type": "module",
  "license": "MIT",
  "bin": {
    "oh-my-docs": "./dist/bin.js",
    "omdocs": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "templates",
    "skills"
  ],
  "scripts": {
    "prebuild": "node --experimental-strip-types ./scripts/sync-templates.ts && node --experimental-strip-types ../../plugins/scripts/sync-skills.ts",
    "build": "tsc -p tsconfig.json",
    "test": "node --test --experimental-strip-types src/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@oh-my-docs/core": "workspace:*",
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ssota-labs/oh-my-docs.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/ssota-labs/oh-my-docs/tree/main/packages/cli",
  "engines": {
    "node": ">=24.0.0"
  }
}
