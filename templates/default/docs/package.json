{
  "name": "docs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build && pnpm run check:planning",
    "start": "next start",
    "postinstall": "fumadocs-mdx",
    "test": "node --test --experimental-strip-types scripts/*.test.ts",
    "typecheck": "tsc --noEmit",
    "check:planning": "node --experimental-strip-types scripts/check-planning.ts"
  },
  "dependencies": {
    "@oh-my-docs/ui": "workspace:*",
    "fumadocs-core": "^16.11.5",
    "fumadocs-mdx": "^15.2.0",
    "fumadocs-ui": "^16.11.5",
    "next": "^16.2.11",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.3",
    "@types/mdx": "^2.0.14",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "postcss": "^8.5.22",
    "tailwindcss": "^4.3.3",
    "typescript": "^5.9.3",
    "yaml": "^2.9.0"
  }
}
